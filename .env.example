# Copier ce fichier en .env et remplir les valeurs

# TOEIC Backend connection (python-sdk)
TOEIC_BACKEND_URL=http://localhost:3000/api/v1
TOEIC_TEACHER_TOKEN=eyJ0eXAiOiJKV1QiLCJhbGc...
TOEIC_SDK_ENABLED=true

# Base de données
# Pour le développement local, SQLite est utilisé automatiquement si cette variable est vide
DATABASE_URL=postgresql://user:password@localhost:5432/toeic_ai_service_db

# Sécurité
API_KEY=your-secret-api-key-here

# Paramètres du moteur (ajustables sans toucher au code)
WEIGHT_GRADE=0.60
WEIGHT_TIME=0.25
WEIGHT_VARIANCE=0.15

THRESHOLD_EASY=0.35
THRESHOLD_MEDIUM=0.60

BOOST_MIN_SCORE=85.0
BOOST_MAX_TIME=0.85

TOP_N_RECOMMENDATIONS=5
COLD_START_MIN_ATTEMPTS=5
CONSOLIDATION_SCORE_THRESHOLD=75.0
